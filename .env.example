# Provider configuration for MGX Librettist.
#
# PROVIDER_MODE=mock  -> always use offline mock providers (no network).
# PROVIDER_MODE=real  -> use a real provider when its API key is present below,
#                        otherwise fall back to mock automatically.
PROVIDER_MODE=mock

# Musixmatch Pro API key (apikey query parameter). When set with PROVIDER_MODE=real,
# the app uses the Analysis API to extract copyright-safe abstract patterns
# (moods, themes, entities) — it never fetches or displays lyrics.
MUSIXMATCH_API_KEY=

# Cyanite — audio analysis provider (integration in progress).
# CYANITE_API_KEY is not used by the webhook endpoint yet; included for the next step.
CYANITE_API_KEY=
CYANITE_API_URL=https://api.cyanite.ai/graphql
# Secret from your Cyanite integration; used to verify the webhook Signature header
# (HMAC-SHA512). If empty, the webhook accepts events without verification (logged).
CYANITE_WEBHOOK_SECRET=

# Optional, for future LLM-backed rewrites / briefs (not required in mock mode).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
